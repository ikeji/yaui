#!/usr/bin/env python3
"""yaui-gtk - GTK runtime for the yaui shell-script UI toolkit.

Usage: yaui-gtk [--debug] SCRIPT [args...]

Same JSON protocol as yaui-tui: SCRIPT writes UI trees to stdout, and reads
event JSON (one per line) from stdin. This program renders the UI with GTK 3.
The script's stderr is inherited from this process so its diagnostic output
appears on the user's terminal as it happens. With --debug, each UI JSON
tree received from the script is also dumped to stderr.
"""

import argparse
import json
import os
import queue
import subprocess
import sys
import threading

import gi
gi.require_version('Gtk', '3.0')
from gi.repository import Gtk, GLib, Gdk  # noqa: E402


# ---------------------------------------------------------------------------
# JSON stream parser (shared protocol with yaui-tui)
# ---------------------------------------------------------------------------

def stream_json_objects(fileobj):
    """Yield successive JSON values from a text stream by tracking depth."""
    buf = []
    depth = 0
    in_string = False
    escape = False
    started = False
    while True:
        ch = fileobj.read(1)
        if ch == '' or ch is None:
            return
        if not started:
            if ch in (' ', '\t', '\n', '\r'):
                continue
            if ch not in ('{', '['):
                continue
            started = True
            buf = [ch]
            depth = 1
            in_string = False
            escape = False
            continue
        buf.append(ch)
        if escape:
            escape = False
            continue
        if in_string:
            if ch == '\\':
                escape = True
            elif ch == '"':
                in_string = False
            continue
        if ch == '"':
            in_string = True
        elif ch in '{[':
            depth += 1
        elif ch in '}]':
            depth -= 1
            if depth == 0:
                text = ''.join(buf)
                try:
                    yield json.loads(text)
                except json.JSONDecodeError:
                    pass
                buf = []
                started = False


# ---------------------------------------------------------------------------
# Subprocess wrapper
# ---------------------------------------------------------------------------

class Script:
    def __init__(self, argv):
        env = dict(os.environ)
        env['YAUI'] = 'gtk'
        # stderr is inherited from the parent so the script's diagnostics
        # appear on the user's terminal in real time.
        self.proc = subprocess.Popen(
            argv,
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            text=True,
            bufsize=1,
            env=env,
        )
        self.q = queue.Queue()
        self._t_out = threading.Thread(target=self._read_stdout, daemon=True)
        self._t_out.start()

    def _read_stdout(self):
        try:
            for obj in stream_json_objects(self.proc.stdout):
                self.q.put(('ui', obj))
        finally:
            self.q.put(('eof', None))

    def send(self, event):
        try:
            self.proc.stdin.write(json.dumps(event, ensure_ascii=False) + '\n')
            self.proc.stdin.flush()
        except (BrokenPipeError, OSError, ValueError):
            pass

    def close_stdin(self):
        try:
            self.proc.stdin.close()
        except Exception:
            pass

    def alive(self):
        return self.proc.poll() is None

    def terminate(self, timeout=0.5):
        if self.alive():
            try:
                self.proc.terminate()
            except Exception:
                pass
        try:
            self.proc.wait(timeout=timeout)
        except subprocess.TimeoutExpired:
            try:
                self.proc.kill()
            except Exception:
                pass


# ---------------------------------------------------------------------------
# Widget builder
# ---------------------------------------------------------------------------

def _children(node):
    c = node.get('children')
    if c is None:
        c = node.get('content')
    if c is None:
        return []
    if isinstance(c, list):
        return c
    return [c]


def _emit(send, base_evt, wid):
    if wid is not None:
        base_evt = dict(base_evt)
        base_evt['id'] = wid
    send(base_evt)


def _item_text(item):
    if isinstance(item, dict):
        return str(item.get('text', item.get('label', item.get('value', ''))))
    return str(item)


# Reconciliation: widgets with an `id` are cached and reused across UI
# updates so their state (Entry text + cursor, focus, ListBox selection)
# survives. ctx is a dict carrying:
#   send  - script.send callable
#   cache - dict[id -> (widget, type)] kept between renders
#   used  - set of ids referenced this render; entries not in `used` are
#           destroyed at the end of apply_ui

def build_widget(node, ctx):
    if not isinstance(node, dict):
        return None
    t = node.get('type')
    wid = node.get('id')

    if wid is not None and wid in ctx['cache']:
        cached_w, cached_t = ctx['cache'][wid]
        if cached_t == t:
            ctx['used'].add(wid)
            _update_widget(cached_w, node, ctx)
            return cached_w
        # Type changed under the same id: drop the old widget.
        cached_w.destroy()
        del ctx['cache'][wid]

    w = _create_widget(node, ctx)
    if w is None:
        return None
    w._yaui_type = t
    if wid is not None:
        ctx['cache'][wid] = (w, t)
        ctx['used'].add(wid)
    _update_widget(w, node, ctx)
    return w


def _block(w, attr):
    hid = getattr(w, attr, None)
    if hid is not None:
        w.handler_block(hid)


def _unblock(w, attr):
    hid = getattr(w, attr, None)
    if hid is not None:
        w.handler_unblock(hid)


def _create_widget(node, ctx):
    t = node.get('type')

    if t == 'label':
        w = Gtk.Label()
        w.set_xalign(0.0)
        w.set_line_wrap(True)
        return w

    if t == 'button':
        w = Gtk.Button()
        w._yaui_clicked_h = w.connect(
            'clicked',
            lambda b: _emit(ctx['send'], {'type': 'click'}, b._yaui_id))
        return w

    if t == 'checkbox':
        w = Gtk.CheckButton()
        w._yaui_toggled_h = w.connect(
            'toggled',
            lambda cb: _emit(ctx['send'],
                             {'type': 'change', 'value': cb.get_active()},
                             cb._yaui_id))
        return w

    if t == 'textbox':
        w = Gtk.Entry()
        w._yaui_changed_h = w.connect(
            'changed',
            lambda e: _emit(ctx['send'],
                            {'type': 'change', 'value': e.get_text()},
                            e._yaui_id))
        w.connect(
            'activate',
            lambda e: _emit(ctx['send'],
                            {'type': 'submit', 'value': e.get_text()},
                            e._yaui_id))
        return w

    if t == 'textarea':
        sw = Gtk.ScrolledWindow()
        sw.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.AUTOMATIC)
        sw.set_shadow_type(Gtk.ShadowType.IN)
        tv = Gtk.TextView()
        tv.set_wrap_mode(Gtk.WrapMode.WORD_CHAR)
        sw.add(tv)
        sw._yaui_tv = tv
        buf = tv.get_buffer()

        def on_changed(b):
            text = b.get_text(b.get_start_iter(), b.get_end_iter(), True)
            _emit(ctx['send'], {'type': 'change', 'value': text}, sw._yaui_id)
        sw._yaui_buf_changed_h = buf.connect('changed', on_changed)
        return sw

    if t == 'progressbar':
        w = Gtk.ProgressBar()
        return w

    if t == 'list':
        sw = Gtk.ScrolledWindow()
        sw.set_policy(Gtk.PolicyType.AUTOMATIC, Gtk.PolicyType.AUTOMATIC)
        sw.set_shadow_type(Gtk.ShadowType.IN)
        sw.set_min_content_width(180)
        lb = Gtk.ListBox()
        lb.set_selection_mode(Gtk.SelectionMode.SINGLE)

        def on_row_selected(_lb, row):
            if row is None:
                return
            _emit(ctx['send'],
                  {'type': 'change',
                   'value': row._yaui_index,
                   'item': row._yaui_item},
                  sw._yaui_id)

        def on_row_activated(_lb, row):
            if row is None:
                return
            _emit(ctx['send'],
                  {'type': 'select',
                   'value': row._yaui_index,
                   'item': row._yaui_item},
                  sw._yaui_id)

        sw._yaui_row_selected_h = lb.connect('row-selected', on_row_selected)
        lb.connect('row-activated', on_row_activated)
        sw.add(lb)
        sw._yaui_lb = lb
        return sw

    if t in ('vbox', 'wbox'):
        return Gtk.Box(orientation=Gtk.Orientation.VERTICAL,
                       spacing=int(node.get('spacing', 6)))
    if t == 'hbox':
        return Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL,
                       spacing=int(node.get('spacing', 6)))

    return Gtk.Label(label=f'<unknown widget: {t!r}>')


def _update_widget(w, node, ctx):
    t = node.get('type')
    w._yaui_id = node.get('id')

    if t == 'label':
        text = str(node.get('text', ''))
        if node.get('bold'):
            w.set_markup('<b>' + GLib.markup_escape_text(text) + '</b>')
        else:
            w.set_text(text)
        return

    if t == 'button':
        w.set_label(str(node.get('text', '')))
        return

    if t == 'checkbox':
        w.set_label(str(node.get('text', '')))
        desired = bool(node.get('checked', False))
        if w.get_active() != desired:
            _block(w, '_yaui_toggled_h')
            w.set_active(desired)
            _unblock(w, '_yaui_toggled_h')
        return

    if t == 'textbox':
        if 'value' in node:
            new_text = str(node.get('value', ''))
            if w.get_text() != new_text:
                # Skip the override while the user is typing in this
                # field; otherwise async round-trip echo could clobber
                # letters already entered. `controlled: true` forces it.
                if node.get('controlled') or not w.has_focus():
                    pos = w.get_position()
                    _block(w, '_yaui_changed_h')
                    w.set_text(new_text)
                    _unblock(w, '_yaui_changed_h')
                    w.set_position(min(pos, len(new_text)))
        if 'width' in node:
            try:
                w.set_width_chars(int(node['width']))
            except (TypeError, ValueError):
                pass
        return

    if t == 'textarea':
        try:
            cols = int(node.get('width', 30))
            rows = int(node.get('height', 5))
        except (TypeError, ValueError):
            cols, rows = 30, 5
        w.set_min_content_width(max(80, cols * 8))
        w.set_min_content_height(max(60, rows * 18))
        if 'value' in node:
            tv = w._yaui_tv
            buf = tv.get_buffer()
            new_text = str(node.get('value', ''))
            cur_text = buf.get_text(buf.get_start_iter(), buf.get_end_iter(), True)
            if cur_text != new_text:
                if node.get('controlled') or not tv.has_focus():
                    buf.handler_block(w._yaui_buf_changed_h)
                    buf.set_text(new_text)
                    buf.handler_unblock(w._yaui_buf_changed_h)
        return

    if t == 'progressbar':
        try:
            v = float(node.get('value', 0))
            m = float(node.get('max', 100))
            ratio = max(0.0, min(1.0, v / m if m else 0))
        except (TypeError, ValueError):
            ratio = 0.0
        w.set_fraction(ratio)
        w.set_show_text(bool(node.get('show_text', False)))
        return

    if t == 'list':
        try:
            rows = int(node.get('height', 6))
        except (TypeError, ValueError):
            rows = 6
        w.set_min_content_height(max(60, rows * 22))
        items = list(node.get('items', []) or [])
        try:
            sel = int(node.get('selected', -1) if node.get('selected', -1) is not None else -1)
        except (TypeError, ValueError):
            sel = -1
        lb = w._yaui_lb
        existing = lb.get_children()

        # Block selection changes during the rebuild so the script
        # doesn't get a flurry of phantom 'change' events.
        lb.handler_block(w._yaui_row_selected_h)
        try:
            for i, item in enumerate(items):
                if i < len(existing):
                    row = existing[i]
                else:
                    row = Gtk.ListBoxRow()
                    label = Gtk.Label()
                    label.set_xalign(0.0)
                    label.set_margin_start(6); label.set_margin_end(6)
                    label.set_margin_top(2);   label.set_margin_bottom(2)
                    row.add(label)
                    row._yaui_label = label
                    lb.add(row)
                row._yaui_label.set_text(_item_text(item))
                row._yaui_item = item
                row._yaui_index = i
            # Remove any leftover rows.
            existing = lb.get_children()
            for row in existing[len(items):]:
                lb.remove(row)
            # Apply selection.
            if 0 <= sel < len(items):
                target = lb.get_row_at_index(sel)
                if target is not None and target is not lb.get_selected_row():
                    lb.select_row(target)
            elif sel < 0:
                lb.unselect_all()
        finally:
            lb.handler_unblock(w._yaui_row_selected_h)
        lb.show_all()
        return

    if t in ('vbox', 'wbox', 'hbox'):
        kids = _children(node)
        existing = w.get_children()
        # Detach any cached descendants (they may move) so we can re-pack.
        for child in existing:
            w.remove(child)
        for c in kids:
            cw = build_widget(c, ctx)
            if cw is None:
                continue
            expand = bool(c.get('expand', False)) if isinstance(c, dict) else False
            w.pack_start(cw, expand, expand, 0)
        return

    # unknown — leave label as-is


# ---------------------------------------------------------------------------
# Window/UI application
# ---------------------------------------------------------------------------

class App:
    def __init__(self, script, debug=False):
        self.script = script
        self.debug = debug
        self.window = Gtk.Window()
        self.window.set_default_size(360, 140)
        self.window.set_title('yaui-gtk')
        self.window.connect('destroy', self._on_destroy)
        self.window.connect('key-press-event', self._on_key)

        self._closing = False
        self._idmap = {}  # id -> (widget, type), persisted across renders
        self._placeholder()
        self.window.show_all()

    def _placeholder(self):
        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        box.set_margin_start(12); box.set_margin_end(12)
        box.set_margin_top(12); box.set_margin_bottom(12)
        lbl = Gtk.Label(label='yaui-gtk: waiting for UI…')
        lbl.set_xalign(0.0)
        box.pack_start(lbl, True, True, 0)
        self.window.add(box)

    def _replace_child(self, child):
        old = self.window.get_child()
        if old is not None:
            self.window.remove(old)
        if child is not None:
            self.window.add(child)
        self.window.show_all()

    def _on_destroy(self, *_):
        if not self._closing:
            self._closing = True
            self.script.send({'type': 'close'})
            self.script.close_stdin()
        Gtk.main_quit()

    def _on_key(self, _widget, event):
        if event.keyval == Gdk.KEY_Escape:
            self._on_destroy()
            return True
        return False

    def apply_ui(self, node):
        if self._closing:
            return False

        # Capture which cached widget currently has focus, so we can
        # restore it after the rebuild. Also remember the cursor position
        # for Entry widgets — `grab_focus()` later in this method would
        # otherwise trigger Entry's default select-all-on-focus behaviour
        # and move the caret to the end.
        focus_id = None
        focus_cursor = None
        focused = self.window.get_focus()
        if focused is not None:
            for k, (cw, _) in self._idmap.items():
                if cw is focused or focused.is_ancestor(cw):
                    focus_id = k
                    if isinstance(cw, Gtk.Entry):
                        focus_cursor = cw.get_position()
                    break

        # Detach every cached widget from its current parent so build_widget
        # can re-attach reused ones into new containers without GTK
        # complaining about double parents.
        for cw, _ in self._idmap.values():
            parent = cw.get_parent()
            if parent is not None:
                parent.remove(cw)

        used = set()
        ctx = {'send': self.script.send, 'cache': self._idmap, 'used': used}

        if isinstance(node, dict) and node.get('type') in ('dialog', 'sdi'):
            title = node.get('title')
            if title:
                self.window.set_title(str(title))
            contents = _children(node)
            if not contents:
                inner = None
            elif len(contents) == 1:
                inner = build_widget(contents[0], ctx)
            else:
                inner = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
                for c in contents:
                    cw = build_widget(c, ctx)
                    if cw is not None:
                        inner.pack_start(cw, False, False, 0)
        else:
            inner = build_widget(node, ctx)

        # Drop cached entries that aren't referenced any more.
        for k in list(self._idmap.keys()):
            if k not in used:
                widget, _ = self._idmap.pop(k)
                widget.destroy()

        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        outer.set_margin_start(12)
        outer.set_margin_end(12)
        outer.set_margin_top(12)
        outer.set_margin_bottom(12)
        if inner is not None:
            outer.pack_start(inner, True, True, 0)
        self._replace_child(outer)

        if focus_id is not None and focus_id in self._idmap:
            cw, _ = self._idmap[focus_id]
            target = getattr(cw, '_yaui_lb', None) or getattr(cw, '_yaui_tv', None) or cw
            target.grab_focus()
            # GtkEntry's default focus behaviour selects all the text and
            # parks the caret at the end. Restore the saved cursor position
            # and collapse the selection.
            if isinstance(target, Gtk.Entry):
                pos = focus_cursor if focus_cursor is not None else target.get_position()
                target.select_region(pos, pos)
        return False  # for GLib.idle_add (don't repeat)

    def consume(self):
        """Background thread: pull from script.q, schedule onto GTK main."""
        while True:
            try:
                kind, payload = self.script.q.get(timeout=0.2)
            except queue.Empty:
                if not self.script.alive():
                    GLib.idle_add(self._quit_when_idle)
                    return
                continue
            if kind == 'eof':
                GLib.idle_add(self._quit_when_idle)
                return
            if kind == 'ui':
                if self.debug:
                    sys.stderr.write('[yaui-gtk UI] ' + json.dumps(payload, ensure_ascii=False) + '\n')
                    sys.stderr.flush()
                GLib.idle_add(self.apply_ui, payload)

    def _quit_when_idle(self):
        Gtk.main_quit()
        return False

    def run(self):
        t = threading.Thread(target=self.consume, daemon=True)
        t.start()
        Gtk.main()


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(prog='yaui-gtk',
                                     description=__doc__.splitlines()[0])
    parser.add_argument('--debug', action='store_true',
                        help='dump each UI tree received from the script to stderr')
    parser.add_argument('script', help='path to the shell script (or any executable)')
    parser.add_argument('args', nargs=argparse.REMAINDER,
                        help='arguments passed to the script')
    ns = parser.parse_args()

    script_path = ns.script
    if os.path.exists(script_path) and os.sep not in script_path:
        script_path = os.path.abspath(script_path)
    argv = [script_path] + (ns.args or [])
    if not os.access(script_path, os.X_OK):
        argv = ['/bin/sh', script_path] + (ns.args or [])

    script = Script(argv)
    app = App(script, debug=ns.debug)
    try:
        app.run()
    finally:
        script.close_stdin()
        script.terminate()

    return script.proc.returncode or 0


if __name__ == '__main__':
    sys.exit(main())
